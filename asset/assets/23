else
targ.Velocity = Vector3.new(0,0,0)
targ.RotVelocity = Vector3.new(0,0,0)
targ.Anchored = true
local v = targ.Transparency
targ.Transparency = 1
wait(0.1)
targ.Transparency = v
end
end

