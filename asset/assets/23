function onButton1Down(mouse)
targ = mouse.Target
if targ==nil then return end
if targ.Locked == true then return end
if targ.Anchored == true then
targ.Velocity = Vector3.new(0,0,0)
targ.RotVelocity = Vector3.new(0,0,0)
